{
  "name": "sonic-topography",
  "private": true,
  "version": "0.0.0",
  "author": "ALEX-W.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "start": "node local-server.mjs",
    "electron": "npm run build && electron .",
    "dist:mac": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dir",
    "dist:dmg": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.alex-w.sonic-topography",
    "productName": "Sonic Topography",
    "copyright": "Copyright © 2026 ALEX-W.",
    "files": [
      "assets/icon/sonic-topography.icns",
      "dist/**/*",
      "electron/**/*",
      "local-server.mjs",
      "package.json",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.music",
      "icon": "assets/icon/sonic-topography.icns",
      "identity": null,
      "target": [
        "dir"
      ]
    }
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "framer-motion": "^12.40.0",
    "jsmediatags": "^3.9.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "music-metadata-browser": "^2.5.11",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsmediatags": "^3.9.6",
    "@types/node": "^22.14.0",
    "@types/three": "^0.184.1",
    "autoprefixer": "^10.4.21",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
